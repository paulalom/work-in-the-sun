{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "types": ["node"],
    "rootDir": ".",
    "outDir": "dist/server",
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmitOnError": true,
    "sourceMap": true
  },
  "include": [
    "server.ts",
    "mcp-server.ts",
    "lib/**/*.ts"
  ],
  "exclude": [
    "ui",
    "dist",
    "node_modules"
  ]
}
