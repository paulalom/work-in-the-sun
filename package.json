{
  "name": "work-in-the-sun",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "node server.js",
    "mcp": "node mcp-server.js",
    "check": "node --check server.js && node --check app/main.js && node --check lib/agent-store.js && node --check lib/codex-bridge.js && node --check lib/codex-catalog.js && node --check lib/window-screenshot.js && node --check mcp-server.js",
    "service:run": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/backend-service-runner.ps1",
    "service:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-backend-service.ps1",
    "service:uninstall": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-backend-service.ps1 -Action Uninstall",
    "service:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-backend-service.ps1 -Action Start",
    "service:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-backend-service.ps1 -Action Stop",
    "service:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-backend-service.ps1 -Action Status",
    "pin:unlock": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clear-pin-lockout.ps1"
  }
}
